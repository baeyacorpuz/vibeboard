rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rooms collection - anyone can create and read rooms
    match /rooms/{roomId} {
      allow read: if true;
      allow create: if true;
      allow update: if true; // Allow updating name field
      
      // Moods subcollection - anyone can submit and read moods
      match /moods/{moodId} {
        allow read: if true;
        allow create: if true;
        allow update: if true; // Allow users to update their own mood
        allow delete: if false; // Prevent deletion of mood data
      }
      
      // Snapshots subcollection - anyone can create and read snapshots
      match /snapshots/{snapshotId} {
        allow read: if true;
        allow create: if true;
      }
    }
  }
}